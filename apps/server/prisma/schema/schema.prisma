generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id     String  @id @default(uuid(7)) @db.Uuid
  email  String  @unique
  rights Right[]
}

model Host {
  id               String     @id @default(uuid(7)) @db.Uuid
  status           HostStatus
  name             String     @default("")
  lastStatusChange DateTime
  rights           Right[]
}

model Right {
  id     String     @id @default(uuid(7)) @db.Uuid
  level  RightLevel
  userId String     @db.Uuid
  user   User       @relation(fields: [userId], references: [id])
  hostId String     @db.Uuid
  host   Host       @relation(fields: [hostId], references: [id])

  @@unique([hostId, userId])
}

enum HostStatus {
  OFF
  RUNNING
  STARTING
  ERROR
}

enum RightLevel {
  ADMIN
  WRITE
  READ
}

model VM {
  id               String   @id @default(uuid(7)) @db.Uuid
  status           VMStatus
  name             String   @default("")
  lastStatusChange DateTime
  vCPU             Int
  ramGB            Int
  cpuAvgPercent    Int
  ramAvgPercent    Int
  cpuPeakPercent   Int
  ramPeakPercent   Int
}

enum VMStatus {
  OFF
  RUNNING
}

model Message {
  id        String   @id @default(uuid(7)) @db.Uuid
  recipient String
  content   String
  createdAt DateTime @default(now())
}

model ApiStatus {
  id          String  @id
  available   Boolean
  maintenance Boolean @default(false)
}

model ManagedDatabase {
  id               String                @id @default(uuid(7)) @db.Uuid
  type             ManagedDatabaseType
  clusterSize      Int
  version          String
  lastStatusChange DateTime
  status           ManagedDatabaseStatus
  adminUser        String
  adminPassword    String
  backups          DatabaseBackup[]
}

enum ManagedDatabaseType {
  POSTGRESQL
  MARIADB
}

enum ManagedDatabaseStatus {
  CREATING
  RUNNING
  UPGRADING
  OFF
}

model DatabaseBackup {
  id               String               @id @default(uuid(7)) @db.Uuid
  targetDatabaseId String               @db.Uuid
  targetDatabase   ManagedDatabase      @relation(fields: [targetDatabaseId], references: [id])
  status           DatabaseBackupStatus
}

enum DatabaseBackupStatus {
  SCHEDULED
  RUNNING
  DONE
}
